# Ignore OS & editor cruft
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.swp
*.swo

# Optional: ignore compiled files or temporary scripts
*.pyc
*.o
*.log

# Optional: ignore backup vsix or cache folders
vscodium/extensions/*.vsix~

# Secrets and credentials
.env
.env.*
*.pem
*.key
*_rsa
*_ecdsa
*_ed25519

